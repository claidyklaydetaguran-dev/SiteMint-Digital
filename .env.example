# AI Receptionist + SiteMint Digital — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# Values shown are empty; see docs/ai-receptionist/SESSION_HANDOFF.md for which are blocking.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=

# ── CRM Twilio (call forwarding + CRM lead SMS — DO NOT use for intake/SMS) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FORWARD_TO_PHONE_NUMBER=

# ── Intake / AI Receptionist Twilio (separate credentials from CRM above) ────
# Used by lib/intakeTwilio.ts for webhook signature validation.
# INTAKE_TWILIO_ACCOUNT_SID is NOT referenced in code — do not add it.
INTAKE_TWILIO_AUTH_TOKEN=

# ── Stripe (AI Receptionist billing) ─────────────────────────────────────────
# STRIPE_RECEPTIONIST_PRICE_ID is required for billing to function (currently missing).
STRIPE_RECEPTIONIST_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# RESEND_FROM_EMAIL: set to a Resend-verified sending address. If missing, falls
# back to hardcoded "SiteMint Digital Solutions <noreply@sitemintdigital.com>".
RESEND_FROM_EMAIL=

# ── AI ────────────────────────────────────────────────────────────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────────
# If missing, admin routes fall back to hardcoded default "sitemint2024" — set this.
ADMIN_PASSWORD=

# ── Platform-managed (do NOT set manually — injected by the artifact system) ──
# BASE_PATH      — injected per-service from artifact.toml [services.env]
# CRM_BASE_URL   — injected by platform for internal Twilio webhook URL construction
