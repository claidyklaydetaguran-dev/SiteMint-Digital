# AI Receptionist + SiteMint Digital — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# Values shown are empty; see docs/ai-receptionist/SESSION_HANDOFF.md for which are blocking.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=

# ── CRM Twilio (call forwarding + CRM lead SMS — DO NOT use for intake/SMS) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
FORWARD_TO_PHONE_NUMBER=

# ── Intake / AI Receptionist Twilio (separate credentials from CRM above) ────
# INTAKE_TWILIO_AUTH_TOKEN is used by lib/intakeTwilio.ts for webhook signature
# validation AND by routes/intakeAgent.ts (sendIntakeSms) to send replies.
# INTAKE_TWILIO_ACCOUNT_SID IS required: routes/intakeAgent.ts (sendIntakeSms,
# line ~350) reads it to send outbound intake SMS. If it is missing, outbound
# intake SMS silently no-ops in production. (A previous version of this file
# incorrectly said it was unreferenced — corrected 2026-07-17.)
INTAKE_TWILIO_ACCOUNT_SID=
INTAKE_TWILIO_AUTH_TOKEN=

# ── Stripe (AI Receptionist billing) ─────────────────────────────────────────
# STRIPE_RECEPTIONIST_PRICE_ID is required for billing to function (currently missing).
STRIPE_RECEPTIONIST_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# RESEND_FROM_EMAIL: set to a Resend-verified sending address. If missing, falls
# back to hardcoded "SiteMint Digital Solutions <noreply@sitemintdigital.com>".
RESEND_FROM_EMAIL=

# ── AI ────────────────────────────────────────────────────────────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────────
# If missing, admin routes fall back to hardcoded default "sitemint2024" — set this.
ADMIN_PASSWORD=

# ── Voice Platform (SiteMint Voice — Milestone 1+) ───────────────────────────
# VOICE_PLATFORM_ENABLED: feature flag for the voice platform (assistants UI +
#   /api/voice/* routes). Enable in development/staging only. MUST remain
#   disabled (unset or "false") in production until owner approval.
#   SMS intake routes are NOT behind this flag and work regardless.
VOICE_PLATFORM_ENABLED=
# VOICE_PROVIDER: "vapi" or "fake". Defaults to "fake" when VAPI_API_KEY is
#   unset. Use "fake" for automated tests and local development without
#   real Vapi credentials.
VOICE_PROVIDER=
# VAPI_API_KEY: PRIVATE Vapi server key. Server-side only — must NEVER be sent
#   to the browser or appear in any API response.
VAPI_API_KEY=
# VAPI_PUBLIC_KEY: Vapi public (browser) key. Only ever delivered to the client
#   through the authenticated, tenant-scoped web-session endpoint.
VAPI_PUBLIC_KEY=
# VAPI_WEBHOOK_SECRET: secret for the Vapi Custom Credential (HMAC preferred,
#   Bearer fallback) that authenticates POST /api/voice/webhooks/vapi.
#   See docs/ai-receptionist/VOICE_PLATFORM.md for the exact scheme.
VAPI_WEBHOOK_SECRET=

# ── Platform-managed (do NOT set manually — injected by the artifact system) ──
# BASE_PATH      — injected per-service from artifact.toml [services.env]
# CRM_BASE_URL   — injected by platform for internal Twilio webhook URL construction
